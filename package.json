{
  "name": "edusphere-os",
  "version": "1.0.0",
  "private": true,
  "description": "AI-Native Telegram LMS for Education Centers",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "db:generate-types": "tsx scripts/gen-types.ts",
    "db:migrate": "cd supabase && supabase db push",
    "db:seed": "tsx scripts/seed-local.ts",
    "prepare": "husky install || true"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.0.0",
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "vitest": "^1.6.0"
  }
}